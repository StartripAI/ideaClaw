% ICLR 2026 Style File (Compatible)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{iclr2026_conference}[2026/01/01 ICLR 2026 style]

\RequirePackage[letterpaper,margin=1in]{geometry}
\RequirePackage{natbib}
\RequirePackage{hyperref}
\RequirePackage{url}
\RequirePackage{booktabs}
\RequirePackage{amsfonts}
\RequirePackage{amsmath}
\RequirePackage{graphicx}
\RequirePackage{microtype}

% ICLR uses single column
\newif\ificlrfinal
\iclrfinalfalse

% Title formatting
\renewcommand{\maketitle}{%
  \begin{center}%
    {\LARGE\bfseries\@title\par}\vspace{1em}%
    {\large\@author\par}\vspace{0.5em}%
    {\normalsize Under review as a conference paper at ICLR 2026\par}%
  \end{center}%
  \vspace{2em}%
}

% Abstract
\renewenvironment{abstract}{%
  \centerline{\bfseries Abstract}%
  \vspace{0.5ex}\begin{quote}\small%
}{\end{quote}}

\endinput
